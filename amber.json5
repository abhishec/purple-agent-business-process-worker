{
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {},
    additionalProperties: false,
  },
  program: {
    image: "public.ecr.aws/d9m7h3k5/agentbench-purple:latest",
    entrypoint: ["python", "main.py", "--host", "0.0.0.0", "--port", "9010"],
    network: {
      endpoints: [
        { name: "endpoint", port: 9010 },
      ],
    },
  },
  slots: {
    green_agent: { kind: "a2a" },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: { a2a: "a2a" },
}

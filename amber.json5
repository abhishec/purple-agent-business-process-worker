{
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {
      anthropic_api_key:  { type: "string", secret: true },
      brainos_api_key:    { type: "string", secret: true },
      brainos_org_id:     { type: "string", secret: true },
      brainos_worker_id:  { type: "string", secret: true },
    },
    required: ["anthropic_api_key"],
    additionalProperties: false,
  },
  program: {
    image: "public.ecr.aws/d9m7h3k5/agentbench-purple:latest",
    entrypoint: ["python", "main.py", "--host", "0.0.0.0", "--port", "9010"],
    env: {
      // CRM gateway oracle URL injected by AgentBeats platform at runtime
      GREEN_AGENT_MCP_URL: "${slots.green_agent.url}",
      // LLM credentials — injected securely from config_schema secrets
      ANTHROPIC_API_KEY:   "${config.anthropic_api_key}",
      BRAINOS_API_KEY:     "${config.brainos_api_key}",
      BRAINOS_ORG_ID:      "${config.brainos_org_id}",
      BRAINOS_WORKER_ID:   "${config.brainos_worker_id}",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9010 },
      ],
    },
  },
  slots: {
    green_agent: { kind: "a2a" },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: { a2a: "a2a" },
}
